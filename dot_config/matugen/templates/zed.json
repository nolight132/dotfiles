{
	"$schema": "https://zed.dev/schema/themes/v0.1.0.json",
	"name": "Matugen-Transparent",
	"author": "Matugen",
	"themes": [
		{
			"appearance": "dark",
			"name": "Matugen-Transparent",
			"style": {
				"editor.background": "{{colors.background.dark.hex}}89",
				"editor.gutter.background": "{{colors.background.dark.hex}}90",
				"editor.foreground": "#e0def4",
				"editor.active_line.background": "{{colors.primary.dark.hex}}15",
				"editor.line_number": "{{colors.outline.dark.hex}}",
				"editor.active_line_number": "{{colors.primary.dark.hex | lighten: 40}}",
				"editor.invisible": "{{colors.outline.dark.hex}}44",
				"editor.wrap_guide": "{{colors.outline.dark.hex}}11",
				"editor.active_wrap_guide": "{{colors.primary.dark.hex | lighten: 40}}33",
				"editor.highlighted_line.background": "{{colors.primary.dark.hex | lighten: 40}}22",
				"editor.document_highlight.read_background": "{{colors.primary.dark.hex | lighten: 40}}55",
				"editor.document_highlight.write_background": "{{colors.primary.dark.hex | lighten: 40}}77",

				"border": "{{colors.background.dark.hex}}00",
				"border.variant": "{{colors.background.dark.hex}}00",
				"border.focused": "{{colors.primary.dark.hex | lighten: 40}}66",
				"border.selected": "{{colors.primary.dark.hex | lighten: 40}}66",

				"text": "#e0def4",
				"text.muted": "{{colors.outline.dark.hex}}",
				"text.accent": "{{colors.primary.dark.hex | lighten: 50}}",

				"surface.background": "transparent",
				"elevated_surface.background": "{{colors.background.dark.hex}}",

				"panel.background": "{{colors.background.dark.hex}}90",
				"panel.focused_border": "{{colors.primary.dark.hex | lighten: 40}}66",
				"background.appearance": "transparent",
				"background": "{{colors.background.dark.hex}}90",

				"status_bar.background": "{{colors.background.dark.hex}}",
				"title_bar.background": "{{colors.background.dark.hex}}",
				"toolbar.background": "{{colors.background.dark.hex}}90",
				"tab_bar.background": "{{colors.background.dark.hex}}90",
				"tab.inactive_background": "{{colors.background.dark.hex}}00",
				"tab.active_background": "{{colors.primary.dark.hex | lighten: 30}}22",

				"element.background": "transparent",
				"element.hover": "{{colors.on_surface_variant.dark.hex}}22",
				"element.active": "{{colors.on_surface_variant.dark.hex}}44",
				"element.selected": "{{colors.primary.dark.hex | lighten: 30}}33",

				"scrollbar.thumb.background": "{{colors.outline.dark.hex}}40",
				"scrollbar.thumb.hover_background": "{{colors.outline.dark.hex}}66",
				"scrollbar.track.background": "transparent",

				"terminal.background": "{{colors.background.dark.hex}}90",
				"terminal.foreground": "{{colors.on_surface_variant.dark.hex}}",

				"created": "#9ccfd8",
				"created.background": "#1e3a3f",
				"modified": "#ebbcba",
				"modified.background": "#442e2c",
				"deleted": "#eb6f92",
				"deleted.background": "#4d1b27",
				"ignored": "{{colors.outline.dark.hex}}88",
				"ignored.background": "{{colors.outline.dark.hex}}22",
				"conflict": "#f6c177",
				"conflict.background": "#4d381a",
				"error": "#eb6f92",
				"error.background": "#4d1b27",
				"warning": "#f6c177",
				"warning.background": "#4d381a",
				"info": "#31748f",
				"info.background": "#0f232b",
				"hint": "#908caa",
				"hint.background": "#2a2832",

				"players": [
					{
						"cursor": "{{colors.primary.dark.hex | lighten: 40}}",
						"background": "{{colors.primary.dark.hex | lighten: 40}}",
						"selection": "{{colors.primary.dark.hex | lighten: 40}}3d"
					},
					{
						"cursor": "{{colors.error.dark.hex}}",
						"background": "{{colors.error.dark.hex}}",
						"selection": "{{colors.error.dark.hex}}3d"
					},
					{
						"cursor": "{{colors.primary.dark.hex | lighten: 40}}",
						"background": "{{colors.primary.dark.hex | lighten: 40}}",
						"selection": "{{colors.primary.dark.hex | lighten: 40}}3d"
					},
					{
						"cursor": "{{colors.tertiary.dark.hex}}",
						"background": "{{colors.tertiary.dark.hex}}",
						"selection": "{{colors.tertiary.dark.hex}}3d"
					},
					{
						"cursor": "{{colors.inverse_primary.dark.hex}}",
						"background": "{{colors.inverse_primary.dark.hex}}",
						"selection": "{{colors.inverse_primary.dark.hex}}3d"
					},
					{
						"cursor": "{{colors.primary_container.dark.hex}}",
						"background": "{{colors.primary_container.dark.hex}}",
						"selection": "{{colors.primary_container.dark.hex}}3d"
					},
					{
						"cursor": "{{colors.on_surface_variant.dark.hex}}",
						"background": "{{colors.on_surface_variant.dark.hex}}",
						"selection": "{{colors.on_surface_variant.dark.hex}}3d"
					},
					{
						"cursor": "{{colors.outline.dark.hex}}",
						"background": "{{colors.outline.dark.hex}}",
						"selection": "{{colors.outline.dark.hex}}3d"
					}
				],

				"terminal.ansi.black": "{{colors.surface.dark.hex}}",
				"terminal.ansi.bright_black": "{{colors.outline.dark.hex}}",
				"terminal.ansi.red": "{{colors.error.dark.hex}}",
				"terminal.ansi.bright_red": "{{colors.error_container.dark.hex}}",
				"terminal.ansi.green": "{{colors.primary.dark.hex | lighten: 40}}",
				"terminal.ansi.bright_green": "{{colors.primary.dark.hex | lighten: 50}}",
				"terminal.ansi.yellow": "{{colors.tertiary.dark.hex | lighten: 30}}",
				"terminal.ansi.bright_yellow": "{{colors.tertiary_container.dark.hex | lighten: 40}}",
				"terminal.ansi.blue": "{{colors.secondary.dark.hex | lighten: 40}}",
				"terminal.ansi.bright_blue": "{{colors.secondary_container.dark.hex | lighten: 50}}",
				"terminal.ansi.magenta": "{{colors.inverse_primary.dark.hex | lighten: 30}}",
				"terminal.ansi.bright_magenta": "{{colors.inverse_primary.dark.hex | lighten: 50}}",
				"terminal.ansi.cyan": "{{colors.primary_container.dark.hex | lighten: 30}}",
				"terminal.ansi.bright_cyan": "{{colors.primary_container.dark.hex | lighten: 50}}",
				"terminal.ansi.white": "{{colors.on_surface_variant.dark.hex}}",
				"terminal.ansi.bright_white": "{{colors.on_surface.dark.hex}}",

				"syntax": {
					"attribute": { "color": "#908caa" },
					"boolean": { "color": "#ebbcba" },
					"comment": { "color": "#6e6a86", "font_style": "italic" },
					"comment.doc": { "color": "#908caa" },
					"constant": { "color": "#e0def4" },
					"constructor": { "color": "#eb6f92" },
					"embedded": { "color": "#e0def4" },
					"emphasis": { "color": "#c4a7e7", "font_style": "italic" },
					"emphasis.strong": { "color": "#9ccfd8", "font_weight": 700 },
					"enum": { "color": "#31748f" },
					"function": { "color": "#ebbcba" },
					"hint": { "color": "#c4a7e7" },
					"keyword": { "color": "#c4a7e7" },
					"label": { "color": "#ebbcba" },
					"link_text": { "color": "#c4a7e7" },
					"link_uri": { "color": "#31748f" },
					"number": { "color": "#9ccfd8" },
					"operator": { "color": "#908caa" },
					"predictive": { "color": "#908caa" },
					"preproc": { "color": "#f6c177" },
					"primary": { "color": "#c4a7e7" },
					"property": { "color": "#9ccfd8" },
					"punctuation": { "color": "#908caa" },
					"punctuation.bracket": { "color": "#908caa" },
					"punctuation.delimiter": { "color": "#908caa" },
					"punctuation.list_marker": { "color": "#908caa", "font_weight": 700 },
					"punctuation.special": { "color": "#31748f" },
					"string": { "color": "#f6c177" },
					"string.escape": { "color": "#f6c177" },
					"string.regex": { "color": "#f6c177" },
					"string.special": { "color": "#31748f" },
					"string.special.symbol": { "color": "#31748f" },
					"tag": { "color": "#ebbcba" },
					"text.literal": { "color": "#f6c177" },
					"title": { "color": "#eb6f92", "font_weight": 700 },
					"type": { "color": "#f6c177" },
					"variable": { "color": "#e0def4" },
					"variable.special": { "color": "#9ccfd8" },
					"variant": { "color": "#ebbcba" }
				}
			}
		}
	]
}
