// background blur
window-rule {
	match app-id=r#"dev.zed.Zed|ghostty$"#
	match
	background-effect {
		blur true
	}
}

// screencast privacy
window-rule {
	match app-id=r#"^org\.telegram\.desktop$"#

	block-out-from "screencast"
}

// telegram fixed width
window-rule {
	match app-id=r#"^org\.telegram\.desktop$"#

	default-column-width { fixed 380; }
}

// workspace routing + maximize
window-rule {
	match app-id=r#"^zen$"#
	open-on-workspace "browser"
	open-maximized-to-edges true
}
window-rule {
	match app-id=r#"^dev\.zed\.Zed$"#
	open-on-workspace "code"
	open-maximized-to-edges true
}
window-rule {
	match app-id=r#"^com\.mitchellh\.ghostty$"#
	open-on-workspace "term"
	open-maximized-to-edges true
}

// chat workspace (left monitor, no autostart)
window-rule {
	match app-id=r#"^cider$"#
	open-on-workspace "chat"
	default-column-width { proportion 0.25; }
}
window-rule {
	match app-id=r#"^discord$"#
	match app-id=r#"(?i)^slack$"#
	open-on-workspace "chat"
	default-column-width { proportion 0.75; }
}

// dolphin floating
window-rule {
	match app-id=r#"^org\.kde\.dolphin$"#
	open-floating true
}

// haruna maximized
window-rule {
	match app-id=r#"^org\.kde\.haruna$"#
	open-maximized-to-edges true
}

// rounded corners
window-rule {
	match is-floating=true
	geometry-corner-radius 12
	clip-to-geometry true
}
