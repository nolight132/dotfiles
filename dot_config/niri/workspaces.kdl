// named workspaces — fixed order, declared once, never reshuffled
// right monitor
workspace "browser" {
	open-on-output "DP-2"
}
workspace "code" {
	open-on-output "DP-2"
}
workspace "term" {
	open-on-output "DP-2"
}
workspace "misc" {
	open-on-output "DP-2"
}

// left monitor
workspace "chat" {
	open-on-output "DP-1"
}
