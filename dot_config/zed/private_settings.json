// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette
{
    "proxy": "",
    "node": {
        "ignore_system_version": true,
    },
    "agent_servers": {
        "claude-acp": {
            "type": "registry",
        },
    },
    "agent": {
        "dock": "right",
        "favorite_models": [],
        "model_parameters": [],
    },
    "diff_view_style": "unified",
    "cli_default_open_behavior": "new_window",
    "outline_panel": {
        "dock": "left",
    },
    "collaboration_panel": {
        "dock": "left",
    },
    "terminal": {
        "shell": {
            "program": "bash",
        },
        "flexible": true,
    },
    "sticky_scroll": {
        "enabled": false,
    },
    "show_edit_predictions": true,
    "diagnostics": {
        "inline": {
            "enabled": true,
        },
    },
    "languages": {
        "TypeScript": {
            "formatter": "prettier",
            "hard_tabs": false,
        },
        "TSX": {
            "formatter": "prettier",
            "hard_tabs": false,
        },
        "JavaScript": {
            "formatter": "prettier",
            "hard_tabs": false,
        },
        "JSON": {
            "hard_tabs": false,
        },
        "JSONC": {
            "hard_tabs": false,
        },
        "HTML": {
            "hard_tabs": false,
        },
        "YAML": {
            "hard_tabs": false,
        },
        "Markdown": {
            "hard_tabs": false,
        },
        "Rust": {
            "hard_tabs": false,
        },
        "Python": {
            "formatter": {
                "language_server": {
                    "name": "ruff",
                },
            },
        },
        "Svelte": {
            "formatter": "prettier",
            "hard_tabs": false,
            "language_servers": [
                "svelte-language-server",
                "eslint",
                "!biome",
                "...",
            ],
        },
        "CSS": {
            "formatter": "prettier",
            "hard_tabs": false,
            "language_servers": [
                "tailwindcss-intellisense-css",
                "!vscode-css-language-server",
                "...",
            ],
        },
        "Go": {
            "formatter": {
                "language_server": {
                    "name": "gopls",
                },
            },
            "format_on_save": "on",
            "code_actions_on_format": {
                "source.organizeImports": true,
            },
            "language_servers": ["gopls", "..."],
            "hard_tabs": true,
        },
    },
    "ui_font_family": ".ZedSans",
    "buffer_line_height": "comfortable",
    "telemetry": {
        "diagnostics": false,
        "metrics": false,
    },
    "tab_size": 4,
    "inlay_hints": {
        "enabled": false,
    },
    "show_signature_help_after_edits": false,
    "auto_signature_help": false,
    "helix_mode": false,
    "prettier": {
        "allowed": true,
    },
    "icon_theme": {
        "mode": "dark",
        "light": "Zed (Default)",
        "dark": "Zed (Default)",
    },
    "git_panel": {
        "dock": "right",
    },
    "buffer_font_size": 14.0,
    "vim_mode": true,
    "vim": {
        "toggle_relative_line_numbers": true,
    },
    "hard_tabs": true,
    "lsp": {
        "vtsls": {
            "settings": {
                "typescript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                },
                "javascript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                },
            },
            "enable_lsp_tasks": true,
        },
        "tailwindcss-language-server": {
            "settings": {
                "includeLanguages": {
                    "svelte": "html",
                },
                "experimental": {
                    "classRegex": [
                        "class=\"([^\"]*)\"",
                        "class='([^']*)'",
                        "class:\\s*([^\\s{]+)",
                        "\\{\\s*class:\\s*\"([^\"]*)\"",
                        "\\{\\s*class:\\s*'([^']*)'",
                    ],
                },
            },
        },
        "typescript-language-server": {
            "settings": {
                "typescript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                },
                "javascript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                },
            },
            "enable_lsp_tasks": true,
        },
        "gopls": {
            "settings": {
                "gofumpt": false,
                "staticcheck": true,
                "completeUnimported": true,
                "usePlaceholders": true,
                "analyses": {
                    "unusedparams": true,
                    "shadow": true,
                },
            },
        },
        "basedpyright": {
            "settings": {
                "analysis": {
                    "diagnosticMode": "workspace",
                    "inlayHints.callArgumentNames": false,
                    "useLibraryCodeForTypes": true,
                },
                "python": {
                    "pythonPath": ".venv/bin/python",
                },
            },
        },
    },
    "edit_predictions": {
        "allow_data_collection": "no",
        "mode": "eager",
        "provider": "zed",
    },
    "buffer_font_family": "JetBrains Mono",
    "git": {
        "inline_blame": {
            "enabled": true,
        },
    },
    "theme": {
        "mode": "dark",
        "light": "Rosé Pine Dawn",
        "dark": "Matugen-Transparent",
    },
    "project_panel": {
        "button": true,
        "default_width": 280,
        "dock": "left",
        "file_icons": true,
        "folder_icons": true,
        "git_status": true,
        "indent_size": 20,
        "auto_reveal_entries": true,
        "auto_fold_dirs": true,
        "scrollbar": {
            "show": null,
        },
        "indent_guides": {
            "show": "always",
        },
    },
    "tabs": {
        "close_position": "right",
        "file_icons": true,
        "git_status": false,
        "activate_on_close": "history",
        "show_close_button": "hover",
    },
    "scrollbar": {
        "show": "auto",
        "cursors": true,
        "git_diff": false,
        "search_results": true,
        "selected_symbol": true,
        "axes": {
            "horizontal": true,
            "vertical": true,
        },
    },
    "format_on_save": "on",
    "calls": {
        "mute_on_join": false,
        "share_on_join": true,
    },
}
